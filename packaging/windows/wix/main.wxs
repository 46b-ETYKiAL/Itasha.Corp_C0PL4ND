<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX v3 installer definition for C0PL4ND, consumed by cargo-wix.

  Build:
    cargo install cargo-wix
    cargo wix            # builds the release binary then the MSI

  Placeholders to replace before GA:
    * UpgradeCode GUID  : generate ONCE with `uuidgen` and keep it stable forever.
    * Manufacturer      : Itasha.Corp
    * License RTF       : packaging/windows/License.rtf (cargo-wix can generate one)
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="C0PL4ND"
    UpgradeCode="00000000-0000-0000-0000-000000000000"
    Manufacturer="Itasha.Corp"
    Language="1033"
    Codepage="1252"
    Version="0.1.0">

    <Package
      Id="*"
      Keywords="Installer"
      Description="C0PL4ND terminal emulator"
      Manufacturer="Itasha.Corp"
      InstallerVersion="450"
      Languages="1033"
      Compressed="yes"
      InstallScope="perMachine"
      SummaryCodepage="1252" />

    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of C0PL4ND is already installed. Setup will now exit." />

    <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1" />
    <Property Id="DiskPrompt" Value="C0PL4ND Installation" />

    <!-- License: MIT OR Apache-2.0. Point at an RTF rendering of the chosen license. -->
    <WixVariable Id="WixUILicenseRtf" Value="packaging\windows\License.rtf" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="APPLICATIONFOLDER" Name="C0PL4ND">
          <Component Id="MainExecutable" Guid="*">
            <File
              Id="c0pl4ndExe"
              Name="c0pl4nd.exe"
              Source="target\release\c0pl4nd.exe"
              KeyPath="yes" />
            <!-- Add the install dir to the per-machine PATH. -->
            <Environment
              Id="UpdatePath"
              Name="PATH"
              Value="[APPLICATIONFOLDER]"
              Permanent="no"
              Part="last"
              Action="set"
              System="yes" />
          </Component>
        </Directory>
      </Directory>

      <!-- Start Menu shortcut. -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="C0PL4ND" />
      </Directory>
    </Directory>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="*">
        <Shortcut
          Id="ApplicationStartMenuShortcut"
          Name="C0PL4ND"
          Description="C0PL4ND terminal emulator"
          Target="[APPLICATIONFOLDER]c0pl4nd.exe"
          WorkingDirectory="APPLICATIONFOLDER" />
        <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Itasha.Corp\C0PL4ND"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="MainFeature" Title="C0PL4ND" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <Icon Id="ProductIcon" SourceFile="packaging\windows\c0pl4nd.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/itasha-corp/c0pl4nd" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/itasha-corp/c0pl4nd" />

    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER" />
  </Product>
</Wix>
