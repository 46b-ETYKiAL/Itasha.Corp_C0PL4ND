<?xml version="1.0" encoding="utf-8"?>
<!--
  C0PL4ND Windows installer. WiX Toolset v6 (dotnet "wix" CLI).
  The release.yml "msi" job builds this; see that workflow for the exact
  invocation (it installs the wix global tool, adds the WixToolset.UI.wixext
  extension, builds the release binary, then runs "wix build" from the repo
  root). Source paths below are relative to the working directory (repo root).
  The UpgradeCode GUID is STABLE: never regenerate it, or upgrades will break.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="C0PL4ND"
    Manufacturer="Itasha.Corp"
    Version="$(var.Version)"
    UpgradeCode="ADBB978D-ED4E-4EE3-A04F-22293BB12275"
    Language="1033"
    Codepage="1252"
    Scope="perMachine">

    <SummaryInformation
      Keywords="terminal,emulator,gpu,rust"
      Description="C0PL4ND — the operator's shell into the wired" />

    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of C0PL4ND is already installed. Setup will now exit." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Install under Program Files\C0PL4ND and add it to the machine PATH. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="C0PL4ND">
        <Component Id="MainExecutable" Guid="*">
          <File
            Id="c0pl4ndExe"
            Name="c0pl4nd.exe"
            Source="target\release\c0pl4nd.exe"
            KeyPath="yes" />
          <Environment
            Id="UpdatePath"
            Name="PATH"
            Value="[INSTALLFOLDER]"
            Permanent="no"
            Part="last"
            Action="set"
            System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="C0PL4ND">
        <Component Id="ApplicationShortcut" Guid="*">
          <Shortcut
            Id="ApplicationStartMenuShortcut"
            Name="C0PL4ND"
            Description="C0PL4ND terminal emulator"
            Target="[INSTALLFOLDER]c0pl4nd.exe"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
          <RegistryValue
            Root="HKCU"
            Key="Software\Itasha.Corp\C0PL4ND"
            Name="installed"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="C0PL4ND" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <!-- Add/Remove Programs metadata + branded icon. -->
    <Icon Id="ProductIcon" SourceFile="packaging\windows\c0pl4nd.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/itasha-corp/c0pl4nd" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/itasha-corp/c0pl4nd" />

    <!-- Install-dir UI with the MIT OR Apache-2.0 license shown to the user. -->
    <WixVariable Id="WixUILicenseRtf" Value="packaging\windows\License.rtf" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <ui:WixUI Id="WixUI_InstallDir" />
  </Package>
</Wix>
